    </column>
    <constraint>
        <name>bancos_online_movimientos_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>bancos_online_mov_unique</name>
        <type>UNIQUE (idcuenta, tx_id)</type>
    </constraint>
</table>
