<?xml version="1.0" encoding="UTF-8"?>
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idcuenta</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>tx_id</name>
