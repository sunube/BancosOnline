<?xml version="1.0" encoding="UTF-8"?>
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idempresa</name>
        <type>integer</type>
    </column>
    <column>
        <name>enablebanking_app_id</name>
        <type>character varying(100)</type>
    </column>
    <column>
        <name>enablebanking_key_pem</name>
        <type>text</type>
    </column>
    <column>
        <name>enablebanking_redirect_url</name>
        <type>character varying(500)</type>
    </column>
    <column>
        <name>sync_frecuencia</name>
        <type>character varying(20)</type>
        <default>'4 hours'</default>
    </column>
    <column>
        <name>dias_historico</name>
        <type>integer</type>
        <default>90</default>
    </column>
    <column>
        <name>activo</name>
        <type>boolean</type>
        <default>true</default>
    </column>
    <column>
        <name>creation_date</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>last_sync</name>
        <type>timestamp</type>
    </column>
    <constraint>
        <name>bancos_online_config_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_bancos_online_config_empresa</name>
        <type>FOREIGN KEY (idempresa) REFERENCES empresas (idempresa) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
